# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_USER=postgres
DB_PASSWORD=ChangeMe123!SecurePassword
DB_NAME=urlshortener

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis is accessed internally via Docker network, no external config needed

# ============================================================================
# GITHUB CONTAINER REGISTRY (GHCR)
# ============================================================================
# This should match your GitHub username
GHCR_USERNAME=yourgithubusername

# ============================================================================
# GO BACKEND CONFIGURATION
# ============================================================================
PORT=8080
GIN_MODE=release
ENVIRONMENT=production

# ============================================================================
# FIREBASE CONFIGURATION (Optional - remove if not using)
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================================
# REACT/VITE FRONTEND CONFIGURATION
# ============================================================================
VITE_API_URL=https://api.shrten.link
VITE_FIREBASE_CONFIG={"apiKey":"your-api-key","projectId":"your-project-id","authDomain":"your-domain.firebaseapp.com","databaseURL":"https://your-project.firebaseio.com","storageBucket":"your-project.appspot.com","messagingSenderId":"your-messaging-id","appId":"your-app-id"}

# ============================================================================
# SSL/TLS CERTIFICATES (for Nginx)
# ============================================================================
# Certificates should be placed in ./certs/ directory
# - shrten.link.crt
# - shrten.link.key
# Use Let's Encrypt for free certificates: https://letsencrypt.org/
